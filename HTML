<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>VEYRO</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,sans-serif;
}

body{
background:#f4f8ff;
color:#111;
overflow-x:hidden;
}

/* SPLASH */

#splash{
position:fixed;
top:0;
left:0;
width:100%;
height:100vh;
background:linear-gradient(135deg,#0f62fe,#0047c7);
display:flex;
justify-content:center;
align-items:center;
font-size:50px;
font-weight:bold;
color:white;
z-index:9999;
letter-spacing:4px;
animation:hideSplash 3s forwards;
}

@keyframes hideSplash{
0%{
opacity:1;
}
80%{
opacity:1;
}
100%{
opacity:0;
visibility:hidden;
}
}

/* LOGIN */

#loginPage{
height:100vh;
display:flex;
justify-content:center;
align-items:center;
padding:20px;
}

.loginBox{
background:white;
width:100%;
max-width:420px;
padding:35px;
border-radius:30px;
box-shadow:0 15px 40px rgba(0,0,0,0.12);
text-align:center;
}

.logo{
font-size:40px;
font-weight:bold;
color:#0f62fe;
margin-bottom:10px;
}

.tag{
color:gray;
margin-bottom:30px;
line-height:1.5;
}

input{
width:100%;
padding:17px;
border:none;
background:#eef4ff;
border-radius:16px;
font-size:16px;
margin-bottom:20px;
outline:none;
}

button{
width:100%;
padding:16px;
border:none;
border-radius:16px;
background:#0f62fe;
color:white;
font-size:17px;
font-weight:bold;
cursor:pointer;
transition:0.3s;
}

button:hover{
transform:scale(1.02);
}

/* HIDDEN */

.hidden{
display:none;
}

/* HEADER */

header{
background:#0f62fe;
color:white;
padding:18px 20px;
display:flex;
justify-content:space-between;
align-items:center;
position:sticky;
top:0;
z-index:100;
}

.menu{
font-size:30px;
cursor:pointer;
}

/* PROFILE */

.profile{
position:fixed;
top:0;
right:-100%;
width:300px;
height:100%;
background:white;
padding:25px;
box-shadow:-5px 0 20px rgba(0,0,0,0.1);
transition:0.4s;
z-index:1000;
overflow-y:auto;
}

.profile.active{
right:0;
}

.profile h2{
color:#0f62fe;
margin-bottom:25px;
}

.profile p{
margin-bottom:15px;
font-size:15px;
}

.logoutBtn{
background:red;
margin-top:20px;
}

/* HERO */

.hero{
padding:35px 20px;
text-align:center;
background:white;
}

.hero h1{
font-size:30px;
margin-bottom:12px;
}

.hero p{
color:gray;
line-height:1.5;
}

/* SERVICES */

.services{
padding:20px;
display:grid;
grid-template-columns:repeat(auto-fit,minmax(160px,1fr));
gap:18px;
}

.card{
background:white;
padding:25px 15px;
border-radius:24px;
box-shadow:0 10px 25px rgba(0,0,0,0.08);
text-align:center;
cursor:pointer;
transition:0.3s;
}

.card:hover{
transform:translateY(-6px);
}

.emoji{
font-size:42px;
margin-bottom:12px;
}

.card h3{
margin-bottom:8px;
}

.card p{
font-size:14px;
color:gray;
}

/* BOOKING */

.booking{
padding:20px;
}

.bookingBox{
background:white;
padding:25px;
border-radius:25px;
box-shadow:0 10px 25px rgba(0,0,0,0.08);
}

.bookingBox h2{
margin-bottom:18px;
}

.price{
font-size:30px;
font-weight:bold;
color:#0f62fe;
margin:20px 0;
}

.status{
margin-top:25px;
background:#eef4ff;
padding:20px;
border-radius:20px;
display:none;
}

.cancelBtn{
margin-top:15px;
background:red;
}

/* FOOTER */

.footer{
background:#0f62fe;
color:white;
text-align:center;
padding:30px 20px;
margin-top:40px;
}

.footer p{
margin-top:10px;
font-size:14px;
}

/* MOBILE */

@media(max-width:600px){

.hero h1{
font-size:24px;
}

.logo{
font-size:34px;
}

}

</style>
</head>

<body>

<!-- SPLASH -->

<div id="splash">
VEYRO
</div>

<!-- LOGIN -->

<div id="loginPage">

<div class="loginBox">

<div class="logo">
VEYRO
</div>

<div class="tag">
Fast & Trusted Home Services at Your Doorstep 🚀
</div>

<input
type="number"
id="mobile"
placeholder="Enter Mobile Number"
>

<button onclick="login()">
Continue with OTP
</button>

</div>

</div>

<!-- HOME -->

<div id="homePage" class="hidden">

<header>

<h2>VEYRO</h2>

<div class="menu" onclick="toggleProfile()">
☰
</div>

</header>

<!-- PROFILE -->

<div class="profile" id="profileBox">

<h2>Customer Profile</h2>

<p><b>Name:</b> Customer</p>

<p><b>Mobile:</b> <span id="showNumber"></span></p>

<p><b>Total Bookings:</b> 2</p>

<p><b>Cancellations:</b> 0</p>

<p><b>Support:</b> Live Chat Available</p>

<p><b>Status:</b> Active User</p>

<button class="logoutBtn" onclick="logout()">
Logout
</button>

</div>

<!-- HERO -->

<div class="hero">

<h1>
Welcome to VEYRO 👋
</h1>

<p>
Book trusted professionals instantly for your home services.
</p>

</div>

<!-- SERVICES -->

<div class="services">

<div class="card" onclick="selectService('Painting','₹799')">
<div class="emoji">🎨</div>
<h3>Painting</h3>
<p>Professional Wall Painting</p>
</div>

<div class="card" onclick="selectService('Plumbing','₹499')">
<div class="emoji">🔧</div>
<h3>Plumbing</h3>
<p>Expert Plumbing Repairs</p>
</div>

<div class="card" onclick="selectService('Cleaning','₹599')">
<div class="emoji">🧹</div>
<h3>Cleaning</h3>
<p>Deep Home Cleaning</p>
</div>

<div class="card" onclick="selectService('Electrician','₹699')">
<div class="emoji">💡</div>
<h3>Electrician</h3>
<p>Electrical Repair Experts</p>
</div>

<div class="card" onclick="selectService('AC Service','₹999')">
<div class="emoji">❄️</div>
<h3>AC Service</h3>
<p>Cooling Service & Repair</p>
</div>

<div class="card" onclick="selectService('Salon','₹899')">
<div class="emoji">💇</div>
<h3>Salon</h3>
<p>Beauty Services at Home</p>
</div>

</div>

<!-- BOOKING -->

<div class="booking">

<div class="bookingBox">

<h2 id="serviceTitle">
Select Service
</h2>

<input
type="text"
id="location"
placeholder="Enter Your Location"
>

<div class="price" id="servicePrice">
--
</div>

<button onclick="bookNow()">
Book Service
</button>

<div class="status" id="bookingStatus">

<h3>
✅ Booking Confirmed
</h3>

<p style="margin-top:12px;">
Professional assigned successfully.
</p>

<p style="margin-top:12px;">
Arriving within 10 minutes 🚀
</p>

<button class="cancelBtn" onclick="cancelBooking()">
Cancel Booking
</button>

</div>

</div>

</div>

<!-- FOOTER -->

<div class="footer">

<h2>VEYRO</h2>

<p>
Fast • Trusted • Professional
</p>

<p>
© 2026 VEYRO. All Rights Reserved.
</p>

</div>

</div>

<script>

let currentService="";

function login(){

let mobile=
document.getElementById("mobile").value;

if(mobile.length!=10){

alert("Enter valid 10 digit mobile number");

return;
}

document.getElementById("showNumber").innerHTML=mobile;

document.getElementById("loginPage")
.classList.add("hidden");

document.getElementById("homePage")
.classList.remove("hidden");

}

function toggleProfile(){

document.getElementById("profileBox")
.classList.toggle("active");

}

function logout(){

location.reload();

}

function selectService(name,price){

currentService=name;

document.getElementById("serviceTitle")
.innerHTML=name;

document.getElementById("servicePrice")
.innerHTML=price;

window.scrollTo({
top:800,
behavior:"smooth"
});

}

function bookNow(){

let location=
document.getElementById("location").value;

if(currentService==""){

alert("Select service");

return;
}

if(location==""){

alert("Enter location");

return;
}

document.getElementById("bookingStatus")
.style.display="block";

}

function cancelBooking(){

let reason=prompt("Reason for cancellation");

if(reason){

alert("Booking Cancelled");

document.getElementById("bookingStatus")
.style.display="none";

}

}

</script>

</body>
</html>
